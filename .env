# Agent Nexus - Environment Variables
# ВАЖНО: Не коммитить в git! Добавить в .gitignore

# ============================================
# SECURITY
# ============================================

# Пароль для доступа к дашборду
NEXUS_PASSWORD=your_secure_password_here

# Секретный ключ для сессий (автогенерация если пусто)
SESSION_SECRET=your_session_secret_here

# IP whitelist (пусто = все разрешены, только пароль)
NEXUS_IP_WHITELIST=

# ============================================
# SERVER
# ============================================

# Порт сервера
NEXUS_PORT=3000

# Хост (0.0.0.0 = все интерфейсы)
NEXUS_HOST=0.0.0.0

# ============================================
# RATE LIMITING
# ============================================

RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================
# PATHS
# ============================================

# База данных
NEXUS_DB_PATH=~/.nexus/nexus.db

# ============================================
# FEATURES
# ============================================

# Время жизни сессии (часы)
SESSION_EXPIRE_HOURS=24
